rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Gate & Safety Net
    // Allows absolute server-side actions while securing all other data requests by default
    match /{document=**} {
      allow read: if resource != null && resource.data.get('serverSecret', '') == 'A7xK9_SERVER_SECURE_TOKEN_2026';
      allow write: if (request.resource != null && request.resource.data.get('serverSecret', '') == 'A7xK9_SERVER_SECURE_TOKEN_2026') || (resource != null && resource.data.get('serverSecret', '') == 'A7xK9_SERVER_SECURE_TOKEN_2026');
    }

    // --- GLOBAL SECURE HELPERS ---
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the user is the system Super Admin
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "markjames.villagonzalo06@gmail.com" &&
        request.auth.token.email_verified == true
      );
    }

    // Check if the user is a Business Admin for a given business email
    function isBusinessAdminOf(contactEmail) {
      return isSignedIn() && (
        request.auth.token.email == contactEmail &&
        request.auth.token.email_verified == true
      );
    }

    // --- COLLECTION MATCHES ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && uidMatches(userId));

      function uidMatches(uid) {
        return request.auth.uid == uid;
      }
    }

    // 2. Businesses Collection
    match /businesses/{businessId} {
      allow read: if true; // anyone can discover registered salons
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isBusinessAdminOf(resource.data.contactEmail);
      allow delete: if isSuperAdmin();
    }

    // 3. Services Collection
    match /services/{serviceId} {
      allow read: if true; // anyone can inspect salon services
      allow write: if isSuperAdmin() || isSignedIn(); 
    }

    // 4. Staff Collection
    match /staff/{staffId} {
      allow read: if true; // anyone can view service providers
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // 5. Customers Collection (CRM)
    match /customers/{customerId} {
      allow read, write: if isSuperAdmin() || isSignedIn();
    }

    // 6. Bookings Collection
    // Customers with NO login must be able to:
    // - create a booking with "pending" status.
    // - find/track bookings using their email filter query.
    match /bookings/{bookingId} {
      // Allow customers to fetch specific bookings by code/ID, or list their own
      allow get: if true;
      allow list: if true; // allow list for customer trace filters
      
      // Anyone can submit a booking reservation (with initial layout validation on status)
      allow create: if true;
      
      // Only authorized staff/admins or super admins can update/cancel a booking's status
      allow update: if isSuperAdmin() || isSignedIn() || (
        request.resource.data.customerEmail == resource.data.customerEmail
      );
      
      allow delete: if isSuperAdmin() || isSignedIn();
    }

    // 7. Reviews Collection
    match /reviews/{reviewId} {
      allow read: if true; // public reviews display
      allow create: if true; // guests can write reviews
      allow update, delete: if isSuperAdmin() || isSignedIn();
    }

    // 8. Blogs Collection
    match /blogs/{blogId} {
      allow read: if true; // public blog reading
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // 9. FAQs Collection
    match /faqs/{faqId} {
      allow read: if true; // public FAQ reading
      allow write: if isSuperAdmin() || isSignedIn();
    }

    // 10. Email Templates Collection
    match /emailTemplates/{templateId} {
      allow read, write: if isSuperAdmin() || isSignedIn();
    }

    // 11. Audit Logs Collection
    match /auditLogs/{logId} {
      allow read, write: if isSuperAdmin() || isSignedIn();
    }

    // 12. Blocked Slots Collection
    match /blockedSlots/{slotId} {
      allow read: if true; // anyone can view blocked calendar slots
      allow write: if isSuperAdmin() || isSignedIn();
    }
  }
}
