# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Optional — auto-detected on Vercel via VERCEL_URL.
# Set manually for custom domains: https://your-project.vercel.app
APP_URL="http://localhost:3000"

# SUPER_ADMIN_EMAIL: Platform owner login (server-side only).
SUPER_ADMIN_EMAIL="unibook562026@gmail.com"

# NODEMAILER SMTP (use unibook562026@gmail.com app password on production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=unibook562026@gmail.com
SMTP_PASS=
SMTP_SENDER="UniBook <unibook562026@gmail.com>"

# Firebase (production on Vercel) — create project at console.firebase.google.com
# Option A: single JSON env var
# FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...","appId":"...","firestoreDatabaseId":"(default)"}
# Option B: individual vars
# FIREBASE_API_KEY=
# FIREBASE_AUTH_DOMAIN=
# FIREBASE_PROJECT_ID=
# FIREBASE_APP_ID=
# FIRESTORE_DATABASE_ID=(default)
